<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Include Spring Boot's default configuration -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_DIR" value="${catalina.base:-${user.home}}"/>
    <property name="LOG_FILE" value="${LOG_DIR}/logs/atwrpg.log"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- daily rollover -->
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.gz</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Disable Notion SDK logging completely -->
    <logger name="notion.api.v1.logging.StdoutLogger" level="OFF" />

    <!-- Framework noise reduction -->
    <logger name="org.atmosphere" level="WARN"/>
    <logger name="org.flywaydb" level="ERROR" />
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.apache.catalina" level="WARN"/>
    <logger name="org.apache.tomcat" level="WARN"/>
    <logger name="com.vaadin" level="WARN"/>
    <logger name="io.github.bonigarcia" level="WARN"/>
    <logger name="org.openqa.selenium" level="WARN"/>

    <!-- Application logging -->
    <logger name="com.github.javydreamercsw" level="INFO" />

    <!-- Demote noisy app init / infrastructure to WARN -->
    <logger name="com.github.javydreamercsw.management.config" level="WARN"/>
    <logger name="com.github.javydreamercsw.management.DataInitializer" level="WARN"/>
    <logger name="com.github.javydreamercsw.management.DatabaseCleaner" level="WARN"/>
    <logger name="com.github.javydreamercsw.management.service.campaign" level="WARN"/>
    <logger name="com.github.javydreamercsw.management.service.system" level="WARN"/>
    <logger name="com.github.javydreamercsw.base.AccountInitializer" level="WARN"/>
    <logger name="com.github.javydreamercsw.base.security.GeneralSecurityUtils" level="WARN"/>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
