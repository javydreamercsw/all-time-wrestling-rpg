# Lombok configuration file
# See https://projectlombok.org/features/configuration

# Stop bubbling - configuration is defined at project root
config.stopBubbling = true

# Add @Generated annotation to lombok-generated code
lombok.addLombokGeneratedAnnotation = true

# Configure Jacksonized to use Jackson 2.x (not 3.x)
# Spring Boot 4.0.1 uses Jackson 2.20.1
lombok.jacksonized.jacksonVersion += 2

